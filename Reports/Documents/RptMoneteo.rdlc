<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <Body>
    <ReportItems>
      <Textbox Name="txtEmpresaNombre">
        <CanGrow>true</CanGrow><KeepTogether>true</KeepTogether>
        <Paragraphs><Paragraph><TextRuns><TextRun>
          <Value>=Parameters!pEmpresaNombre.Value</Value>
          <Style><FontFamily>Segoe UI</FontFamily><FontSize>14pt</FontSize><FontWeight>Bold</FontWeight><Color>#333333</Color></Style>
        </TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
        <Top>0cm</Top><Left>0cm</Left><Height>0.8cm</Height><Width>12cm</Width>
        <Style><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style>
      </Textbox>
      <Textbox Name="txtEmpresaInfo">
        <CanGrow>true</CanGrow><KeepTogether>true</KeepTogether>
        <Paragraphs><Paragraph><TextRuns><TextRun>
          <Value>=Parameters!pEmpresaDireccion.Value &amp; " | RUC: " &amp; Parameters!pEmpresaRUC.Value</Value>
          <Style><FontFamily>Segoe UI</FontFamily><FontSize>8pt</FontSize><Color>#666666</Color></Style>
        </TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
        <Top>0.8cm</Top><Left>0cm</Left><Height>0.5cm</Height><Width>12cm</Width>
        <Style><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style>
      </Textbox>
      <Textbox Name="txtTitulo">
        <CanGrow>true</CanGrow><KeepTogether>true</KeepTogether>
        <Paragraphs><Paragraph><TextRuns><TextRun>
          <Value>MONETEO DE CAJA — CONTEO DE EFECTIVO</Value>
          <Style><FontFamily>Segoe UI</FontFamily><FontSize>12pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style>
        </TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
        <Top>1.5cm</Top><Left>0cm</Left><Height>0.7cm</Height><Width>12cm</Width>
        <Style><BackgroundColor>#2D3436</BackgroundColor><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style>
      </Textbox>

      <!-- Info del moneteo -->
      <Textbox Name="lblEncL"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether>
        <Paragraphs><Paragraph><TextRuns><TextRun><Value>Encargado:</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>8.5pt</FontSize><FontWeight>Bold</FontWeight><Color>#555555</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs>
        <Top>2.4cm</Top><Left>0cm</Left><Height>0.45cm</Height><Width>3cm</Width>
        <Style><PaddingLeft>4pt</PaddingLeft><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style>
      </Textbox>
      <Textbox Name="txtEncV"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether>
        <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Parameters!pEncargado.Value</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>8.5pt</FontSize><Color>#333333</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs>
        <Top>2.4cm</Top><Left>3cm</Left><Height>0.45cm</Height><Width>9cm</Width>
        <Style><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style>
      </Textbox>
      <Textbox Name="lblFchL"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether>
        <Paragraphs><Paragraph><TextRuns><TextRun><Value>Fecha / Hora:</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>8.5pt</FontSize><FontWeight>Bold</FontWeight><Color>#555555</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs>
        <Top>2.9cm</Top><Left>0cm</Left><Height>0.45cm</Height><Width>3cm</Width>
        <Style><PaddingLeft>4pt</PaddingLeft><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style>
      </Textbox>
      <Textbox Name="txtFchV"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether>
        <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Parameters!pFecha.Value &amp; "  " &amp; Parameters!pHora.Value</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>8.5pt</FontSize><Color>#333333</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs>
        <Top>2.9cm</Top><Left>3cm</Left><Height>0.45cm</Height><Width>9cm</Width>
        <Style><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style>
      </Textbox>

      <!-- Separador -->
      <Textbox Name="sep1"><CanGrow>false</CanGrow><KeepTogether>true</KeepTogether>
        <Paragraphs><Paragraph><TextRuns><TextRun><Value></Value></TextRun></TextRuns></Paragraph></Paragraphs>
        <Top>3.45cm</Top><Left>0cm</Left><Height>0.05cm</Height><Width>12cm</Width>
        <Style><BackgroundColor>#CCCCCC</BackgroundColor></Style>
      </Textbox>

      <!-- Tabla de denominaciones -->
      <Tablix Name="TablixMoneteo">
        <TablixBody>
          <TablixColumns>
            <TablixColumn><Width>4cm</Width></TablixColumn>
            <TablixColumn><Width>4cm</Width></TablixColumn>
            <TablixColumn><Width>4cm</Width></TablixColumn>
          </TablixColumns>
          <TablixRows>
            <TablixRow>
              <Height>0.65cm</Height>
              <TablixCells>
                <TablixCell><CellContents><Textbox Name="MH1"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>Denominación</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style><Width>0.5pt</Width></Border><BackgroundColor>#2D3436</BackgroundColor><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="MH2"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>Cantidad</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style><Width>0.5pt</Width></Border><BackgroundColor>#2D3436</BackgroundColor><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="MH3"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>Subtotal</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>White</Color><Style>Solid</Style><Width>0.5pt</Width></Border><BackgroundColor>#2D3436</BackgroundColor><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>4pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell>
              </TablixCells>
            </TablixRow>
            <TablixRow>
              <Height>0.6cm</Height>
              <TablixCells>
                <TablixCell><CellContents><Textbox Name="MC1"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!DenominacionTexto.Value</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>#E0E0E0</Color><Style>Solid</Style><Width>0.5pt</Width></Border><BackgroundColor>=IIF(RowNumber(Nothing) Mod 2 = 0, "#F5FFF5", "White")</BackgroundColor><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="MC2"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!Cantidad.Value</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>#E0E0E0</Color><Style>Solid</Style><Width>0.5pt</Width></Border><BackgroundColor>=IIF(RowNumber(Nothing) Mod 2 = 0, "#F5FFF5", "White")</BackgroundColor><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="MC3"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!Subtotal.Value</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#27AE60</Color><Format>S/ #,##0.00</Format></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>#E0E0E0</Color><Style>Solid</Style><Width>0.5pt</Width></Border><BackgroundColor>=IIF(RowNumber(Nothing) Mod 2 = 0, "#F5FFF5", "White")</BackgroundColor><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>4pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell>
              </TablixCells>
            </TablixRow>
          </TablixRows>
        </TablixBody>
        <TablixColumnHierarchy><TablixMembers><TablixMember /><TablixMember /><TablixMember /></TablixMembers></TablixColumnHierarchy>
        <TablixRowHierarchy><TablixMembers><TablixMember><KeepWithGroup>After</KeepWithGroup><RepeatOnNewPage>true</RepeatOnNewPage></TablixMember><TablixMember><Group Name="DetailsMoneteo" /></TablixMember></TablixMembers></TablixRowHierarchy>
        <DataSetName>DsMoneteoCaja</DataSetName>
        <Top>3.55cm</Top><Left>0cm</Left><Height>1.25cm</Height><Width>12cm</Width><ZIndex>10</ZIndex>
        <Style />
      </Tablix>

      <!-- Total general -->
      <Textbox Name="txtTotalBar">
        <CanGrow>true</CanGrow><KeepTogether>true</KeepTogether>
        <Paragraphs><Paragraph><TextRuns><TextRun>
          <Value>="TOTAL CONTADO:   S/ " &amp; Format(Sum(Fields!Subtotal.Value, "DsMoneteoCaja"), "N2")</Value>
          <Style><FontFamily>Segoe UI</FontFamily><FontSize>12pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style>
        </TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs>
        <Top>5.05cm</Top><Left>0cm</Left><Height>0.7cm</Height><Width>12cm</Width><ZIndex>11</ZIndex>
        <Style><BackgroundColor>#2D3436</BackgroundColor><VerticalAlign>Middle</VerticalAlign><PaddingLeft>6pt</PaddingLeft><PaddingRight>8pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style>
      </Textbox>

      <Textbox Name="txtFechaGen">
        <CanGrow>true</CanGrow><KeepTogether>true</KeepTogether>
        <Paragraphs><Paragraph><TextRuns><TextRun>
          <Value>="Generado: " &amp; Parameters!pFechaGeneracion.Value</Value>
          <Style><FontFamily>Segoe UI</FontFamily><FontSize>8pt</FontSize><Color>#888888</Color></Style>
        </TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs>
        <Top>5.85cm</Top><Left>0cm</Left><Height>0.4cm</Height><Width>12cm</Width><ZIndex>12</ZIndex>
        <Style><PaddingRight>4pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style>
      </Textbox>
    </ReportItems>
    <Height>6.5cm</Height>
    <Style />
  </Body>
  <Width>12cm</Width>
  <Page>
    <PageFooter>
      <Height>0.8cm</Height><PrintOnFirstPage>true</PrintOnFirstPage><PrintOnLastPage>true</PrintOnLastPage>
      <ReportItems>
        <Textbox Name="txtPageNum"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether>
          <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Globals!PageNumber &amp; " de " &amp; Globals!TotalPages</Value><Style><FontFamily>Segoe UI</FontFamily><FontSize>8pt</FontSize><Color>#888888</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
          <Top>0cm</Top><Left>0cm</Left><Height>0.6cm</Height><Width>12cm</Width>
          <Style><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style>
        </Textbox>
      </ReportItems>
      <Style />
    </PageFooter>
    <PageHeight>29.7cm</PageHeight><PageWidth>21cm</PageWidth>
    <LeftMargin>2cm</LeftMargin><RightMargin>2cm</RightMargin><TopMargin>2cm</TopMargin><BottomMargin>2cm</BottomMargin>
    <Style />
  </Page>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="SistemaPOSDataSource">
      <ConnectionProperties><DataProvider>System.Data.DataSet</DataProvider><ConnectString>/* Local Report */</ConnectString></ConnectionProperties>
      <rd:DataSourceID>c3d4e5f6-a7b8-9012-cdef-444444444444</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DsMoneteoCaja">
      <Query><DataSourceName>SistemaPOSDataSource</DataSourceName><CommandText>/* Local Report */</CommandText></Query>
      <Fields>
        <Field Name="Denominacion"><DataField>Denominacion</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="DenominacionTexto"><DataField>DenominacionTexto</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Cantidad"><DataField>Cantidad</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="Subtotal"><DataField>Subtotal</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="pEmpresaNombre"><DataType>String</DataType><AllowBlank>true</AllowBlank><Prompt>Empresa</Prompt></ReportParameter>
    <ReportParameter Name="pEmpresaDireccion"><DataType>String</DataType><AllowBlank>true</AllowBlank><Prompt>Direccion</Prompt></ReportParameter>
    <ReportParameter Name="pEmpresaRUC"><DataType>String</DataType><AllowBlank>true</AllowBlank><Prompt>RUC</Prompt></ReportParameter>
    <ReportParameter Name="pFechaGeneracion"><DataType>String</DataType><AllowBlank>true</AllowBlank><Prompt>FechaGen</Prompt></ReportParameter>
    <ReportParameter Name="pEncargado"><DataType>String</DataType><AllowBlank>true</AllowBlank><Prompt>Encargado</Prompt></ReportParameter>
    <ReportParameter Name="pFecha"><DataType>String</DataType><AllowBlank>true</AllowBlank><Prompt>Fecha</Prompt></ReportParameter>
    <ReportParameter Name="pHora"><DataType>String</DataType><AllowBlank>true</AllowBlank><Prompt>Hora</Prompt></ReportParameter>
  </ReportParameters>
  <rd:ReportUnitType>Cm</rd:ReportUnitType>
  <rd:ReportID>c3d4e5f6-a7b8-9012-cdef-444444444445</rd:ReportID>
</Report>
