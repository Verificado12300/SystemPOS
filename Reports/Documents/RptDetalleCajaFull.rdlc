      <!-- Sección: Ventas del turno -->
      <Textbox Name="txtSecVentas">
        <CanGrow>true</CanGrow><KeepTogether>true</KeepTogether>
        <Paragraphs><Paragraph><TextRuns><TextRun>
          <Value>VENTAS DEL TURNO</Value>
          <Style><FontFamily>Segoe UI</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style>
        </TextRun></TextRuns><Style><TextAlign>Left</TextAlign></Style></Paragraph></Paragraphs>
