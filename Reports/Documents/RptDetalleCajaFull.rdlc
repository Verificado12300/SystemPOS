      <Tablix Name="TablixVentas">
        <TablixBody>
          <TablixColumns>
            <TablixColumn><Width>1.5cm</Width></TablixColumn>
            <TablixColumn><Width>3cm</Width></TablixColumn>
            <TablixColumn><Width>7cm</Width></TablixColumn>
            <TablixColumn><Width>2.5cm</Width></TablixColumn>
            <TablixColumn><Width>3cm</Width></TablixColumn>
          </TablixColumns>
          <TablixRows>
            <TablixRow>
              <Height>0.6cm</Height>
              <TablixCells>
