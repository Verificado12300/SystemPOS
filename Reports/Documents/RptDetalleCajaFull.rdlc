<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <Body>
    <ReportItems>
      <!-- Encabezado empresa -->
      <Textbox Name="txtEmpresaNombre">
        <CanGrow>true</CanGrow><KeepTogether>true</KeepTogether>
        <Paragraphs><Paragraph><TextRuns><TextRun>
          <Value>=Parameters!pEmpresaNombre.Value</Value>
          <Style><FontFamily>Segoe UI</FontFamily><FontSize>14pt</FontSize><FontWeight>Bold</FontWeight><Color>#333333</Color></Style>
        </TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
        <Top>0cm</Top><Left>0cm</Left><Height>0.8cm</Height><Width>17cm</Width>
        <Style><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style>
      </Textbox>
      <Textbox Name="txtEmpresaInfo">
        <CanGrow>true</CanGrow><KeepTogether>true</KeepTogether>
        <Paragraphs><Paragraph><TextRuns><TextRun>
          <Value>=Parameters!pEmpresaDireccion.Value &amp; " | RUC: " &amp; Parameters!pEmpresaRUC.Value</Value>
          <Style><FontFamily>Segoe UI</FontFamily><FontSize>8pt</FontSize><Color>#666666</Color></Style>
        </TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
        <Top>0.8cm</Top><Left>0cm</Left><Height>0.5cm</Height><Width>17cm</Width>
        <Style><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style>
      </Textbox>
      <!-- Título -->
      <Textbox Name="txtTitulo">
        <CanGrow>true</CanGrow><KeepTogether>true</KeepTogether>
        <Paragraphs><Paragraph><TextRuns><TextRun>
          <Value>DETALLE DE TURNO DE CAJA</Value>
          <Style><FontFamily>Segoe UI</FontFamily><FontSize>12pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style>
        </TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
        <Top>1.5cm</Top><Left>0cm</Left><Height>0.7cm</Height><Width>17cm</Width>
        <Style><BackgroundColor>#2D3436</BackgroundColor><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style>
      </Textbox>
      <Textbox Name="txtFechaGen">
        <CanGrow>true</CanGrow><KeepTogether>true</KeepTogether>
        <Paragraphs><Paragraph><TextRuns><TextRun>
          <Value>="Generado: " &amp; Parameters!pFechaGeneracion.Value</Value>
          <Style><FontFamily>Segoe UI</FontFamily><FontSize>8pt</FontSize><Color>#888888</Color></Style>
        </TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs>
        <Top>2.3cm</Top><Left>0cm</Left><Height>0.4cm</Height><Width>17cm</Width>
        <Style><PaddingRight>4pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style>
      </Textbox>

